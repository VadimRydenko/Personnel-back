// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  name               String?
  mustChangePassword Boolean   @default(false) @map("must_change_password")
  tempPassword       String?   @map("temp_password")
  passwordChangedAt  DateTime? @map("password_changed_at")
  blocked            Boolean   @default(false)
  blockReason        String?   @map("block_reason")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  sessions           Session[]
  accounts           Account[]
  roles              UserRole[]
  groups             UserGroup[]
  permissions        UserPermission[]
  // --- Better Auth (обов'язкові колонки; у додатку не читаються й не пишуться) ---
  /// За замовчуванням false; верифікація email не увімкнена
  emailVerified      Boolean   @default(false)
  image              String?

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id         String  @id
  accountId  String
  providerId String
  userId     String
  password   String?
  // --- Better Auth: OAuth (обов'язкові колонки; не використовуються — залишаються NULL) ---
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  // --- Better Auth: метадані (у додатку не читаються) ---
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

/// Коди верифікації Better Auth; у додатку не використовується
model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Role {
  id       Int        @id @default(autoincrement())
  roleName String     @unique
  notes    String?
  users    UserRole[]

  @@map("role")
}

model UserRole {
  userId String
  roleId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_role")
}

model Group {
  id          String            @id @default(uuid())
  name        String
  slug        String            @unique
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  permissions GroupPermission[]
  users       UserGroup[]

  @@map("group")
}

model Permission {
  id          String             @id @default(uuid())
  code        String             @unique
  label       String
  description String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  groups      GroupPermission[]
  users       UserPermission[]

  @@map("permission")
}

model GroupPermission {
  groupId      String
  permissionId String
  group        Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([groupId, permissionId])
  @@index([permissionId])
  @@map("group_permission")
}

model UserGroup {
  userId  String
  groupId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
  @@index([groupId])
  @@map("user_group")
}

model UserPermission {
  userId       String
  permissionId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@index([permissionId])
  @@map("user_permission")
}
