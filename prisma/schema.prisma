// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  name               String?
  mustChangePassword Boolean   @default(false) @map("must_change_password")
  tempPassword       String?   @map("temp_password")
  passwordChangedAt  DateTime? @map("password_changed_at")
  blocked            Boolean   @default(false)
  blockReason        String?   @map("block_reason")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  sessions           Session[]
  accounts           Account[]
  roles              UserRole[]
  groups             UserGroup[]
  permissions        UserPermission[]
  /// Прив'язка до картки співробітника (legacy WEB_MEN.MAN → MAN.CODE); опційно
  employeeCode       Int?      @unique @map("employee_code")
  employee           Employee? @relation(fields: [employeeCode], references: [code], onDelete: SetNull)
  // --- Better Auth (обов'язкові колонки; у додатку не читаються й не пишуться) ---
  /// За замовчуванням false; верифікація email не увімкнена
  emailVerified      Boolean   @default(false)
  image              String?

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id         String  @id
  accountId  String
  providerId String
  userId     String
  password   String?
  // --- Better Auth: OAuth (обов'язкові колонки; не використовуються — залишаються NULL) ---
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  // --- Better Auth: метадані (у додатку не читаються) ---
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

/// Коди верифікації Better Auth; у додатку не використовується
model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Role {
  id       Int        @id @default(autoincrement())
  roleName String     @unique
  notes    String?
  users    UserRole[]

  @@map("role")
}

model UserRole {
  userId String
  roleId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_role")
}

model Group {
  id          String            @id @default(uuid())
  name        String
  slug        String            @unique
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  permissions GroupPermission[]
  users       UserGroup[]

  @@map("group")
}

model Permission {
  id          String             @id @default(uuid())
  code        String             @unique
  label       String
  description String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  groups      GroupPermission[]
  users       UserPermission[]

  @@map("permission")
}

model GroupPermission {
  groupId      String
  permissionId String
  group        Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([groupId, permissionId])
  @@index([permissionId])
  @@map("group_permission")
}

model UserGroup {
  userId  String
  groupId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
  @@index([groupId])
  @@map("user_group")
}

model UserPermission {
  userId       String
  permissionId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@index([permissionId])
  @@map("user_permission")
}

/// Довідник типів наказів (DORDER)
model DOrder {
  code Int    @id @default(autoincrement())
  val  String

  @@map("dorder")
}

/// Наказ (ORDERS)
model Order {
  code       Int        @id @default(autoincrement())
  orderWhose Int        @map("order_whose")
  orderNo    String     @map("order_no") @db.VarChar(10)
  orderDate  DateTime   @map("order_date")
  employeePlaces   EmployeePlace[]
  placesCreated    Place[]     @relation("PlaceCreateOrder")
  placesDestroyed  Place[]     @relation("PlaceDestroyOrder")
  beginWorks       BeginWork[]

  @@unique([orderDate, orderNo, orderWhose], map: "orders_struct")
  @@index([orderWhose])
  @@index([orderDate])
  @@map("orders")
}

/// Довідник національностей (DNATIONALITY)
model DNationality {
  code      Int        @id @default(autoincrement())
  val       String     @unique @db.VarChar(20)
  employees Employee[]

  @@map("dnationality")
}

/// Довідник звідки прийшов (DWHEREFREE)
model DWhereFree {
  code      Int        @id @default(autoincrement())
  val       String     @unique @db.VarChar(100)
  employees Employee[]

  @@map("dwherefree")
}

/// Довідник сімейного стану (DFAMILYMODE)
model DFamilyMode {
  code      Int        @id @default(autoincrement())
  val       String     @unique @db.VarChar(20)
  employees Employee[]

  @@map("dfamilymode")
}

/// Довідник найменувань підрозділів (DUNIT)
model DUnit {
  code Int    @id @default(autoincrement())
  val  String @unique
  key  String

  @@map("dunit")
}

/// Довідник найменувань посад (DPLACE)
model DPlace {
  code   Int     @id @default(autoincrement())
  val    String  @unique
  places Place[]

  @@map("dplace")
}

/// Довідник штатних звань (DRANK)
model DRank {
  code Int    @id @default(autoincrement())
  val  String @unique

  @@map("drank")
}

/// Довідник типів посад (DPOSTYPE)
model DPosType {
  code       Int         @id @default(autoincrement())
  val        String      @unique @db.VarChar(50)
  rating     Float?
  places     Place[]
  beginWorks BeginWork[]

  @@map("dpostype")
}

/// Прийом на службу (BEGINWORK)
model BeginWork {
  code         Int       @id @default(autoincrement())
  employeeCode Int       @map("man")
  employee     Employee  @relation("EmployeeBeginWorks", fields: [employeeCode], references: [code], onDelete: Restrict)
  posTypeCode  Int       @map("postype")
  posType      DPosType  @relation(fields: [posTypeCode], references: [code], onDelete: Restrict)
  orderCode    Int       @map("whatorder")
  order        Order     @relation(fields: [orderCode], references: [code], onDelete: Restrict)
  fromDate     DateTime  @map("fromdate") @db.Date
  lastForEmployee Employee? @relation("EmployeeLastBeginWork")

  @@index([employeeCode])
  @@index([fromDate])
  @@map("beginwork")
}

/// Підрозділ (UNITS)
model OrgUnit {
  code             Int       @id @default(autoincrement())
  parentCode       Int?      @map("parent")
  parent           OrgUnit?  @relation("OrgUnitTree", fields: [parentCode], references: [code], onDelete: Restrict)
  children         OrgUnit[] @relation("OrgUnitTree")
  unitTypeCode     Int       @map("unit")
  name             String    @default("") @map("name")
  shortName        String?   @map("short_name")
  sortOrder        Int       @map("unit_id")
  validFrom        DateTime  @map("create_date") @db.Date
  validTo          DateTime? @map("destroy_date") @db.Date
  createOrderCode  Int       @map("create_order")
  destroyOrderCode Int?      @map("destroy_order")
  stationing       String    @default("") @db.VarChar(100)
  places           Place[]

  @@index([parentCode])
  @@index([parentCode, sortOrder])
  @@index([validFrom, validTo])
  @@map("units")
}

/// Штатна посада (PLACES)
model Place {
  code             Int        @id @default(autoincrement())
  orgUnitCode      Int        @map("unit")
  orgUnit          OrgUnit    @relation(fields: [orgUnitCode], references: [code], onDelete: Restrict)
  placeTypeCode    Int        @map("place")
  placeType        DPlace     @relation(fields: [placeTypeCode], references: [code], onDelete: Restrict)
  sortOrder        Int        @default(0) @map("place_id")
  /// FK → DRANK.CODE (штатне звання)
  rankCode         Int?      @map("rank")
  /// FK → DRANK.CODE (подвійна тарифна ставка; DEFAULT 86 у Firebird)
  doubleTariffRankCode Int    @default(86) @map("doubletariffrank")
  posTypeCode      Int        @map("postype")
  posType          DPosType   @relation(fields: [posTypeCode], references: [code], onDelete: Restrict)
  /// Тарифний розряд 0–20 (TARIFFRATE у Firebird)
  tariffRate       Int        @default(0) @map("tariffrate") @db.SmallInt
  posCount         Float      @default(1) @map("pos_count")
  percentRate      Float      @default(0) @map("percentrate")
  isChief          Boolean    @default(false) @map("is_chief")
  manCount         Int        @default(0) @map("man_count") @db.SmallInt
  validFrom        DateTime   @map("create_date") @db.Date
  validTo          DateTime?  @map("destroy_date") @db.Date
  createOrderCode  Int            @map("create_order")
  createOrder      Order          @relation("PlaceCreateOrder", fields: [createOrderCode], references: [code], onDelete: Restrict)
  destroyOrderCode Int?           @map("destroy_order")
  destroyOrder     Order?         @relation("PlaceDestroyOrder", fields: [destroyOrderCode], references: [code], onDelete: Restrict)
  /// FK → DUNIT.CODE (ревізія підрозділу)
  unitRevisionCode Int?           @map("unitrevision")
  employeePlaces        EmployeePlace[]
  documents             Document[]

  @@index([orgUnitCode])
  @@index([orgUnitCode, sortOrder])
  @@index([validFrom, validTo])
  @@map("places")
}

/// Співробітник (EMPLOYEE) — відповідає таблиці MAN у Firebird staff
model Employee {
  code                Int        @id @default(autoincrement())
  lastName            String     @map("lastname") @db.VarChar(30)
  signature           String     @db.VarChar(30)
  firstName           String     @map("firstname") @db.VarChar(20)
  middleName          String     @map("middlename") @db.VarChar(20)
  bornPlace           String     @default("Нема даних") @map("bornplace") @db.VarChar(100)
  birthday            DateTime?  @db.Date
  personalNo          String?    @map("personalno") @db.Char(8)
  nationalityCode     Int         @map("nationality")
  nationality         DNationality @relation(fields: [nationalityCode], references: [code], onDelete: Restrict)
  sex                 String      @default("Ч") @db.Char(1)
  idNo                String?     @unique @map("idno") @db.Char(10)
  fromWhereCode       Int         @map("fromwhere")
  fromWhere           DWhereFree  @relation(fields: [fromWhereCode], references: [code], onDelete: Restrict)
  sciLevel            String?     @map("scilevel") @db.VarChar(50)
  sciRank             String?     @map("scirank") @db.VarChar(50)
  vonDate             DateTime?   @map("vondate") @db.Date
  vlastCalced         DateTime?   @map("vlastcalced") @db.Date
  familyModeCode      Int         @map("familymode")
  familyMode          DFamilyMode @relation(fields: [familyModeCode], references: [code], onDelete: Restrict)
  homeAddress         String     @default("Нема даних") @map("homeaddress") @db.VarChar(100)
  validFrom           DateTime?  @map("fromdate") @db.Date
  validTo             DateTime   @default(dbgenerated("'2999-12-31'::date")) @map("todate") @db.Date
  lastRankCode        Int?       @map("last_rank")
  lastPlaceCode       Int?       @unique @map("last_place")
  lastBeginworkCode   Int?       @unique @map("last_beginwork")
  lastBeginWork       BeginWork? @relation("EmployeeLastBeginWork", fields: [lastBeginworkCode], references: [code], onDelete: SetNull)
  lastEducationCode   Int?       @map("last_education")
  lastMaryCode        Int?       @map("last_mary")
  remarks             String?
  beginWorks          BeginWork[]     @relation("EmployeeBeginWorks")
  employeePlaces      EmployeePlace[] @relation("EmployeeEmployeePlaces")
  lastPlace           EmployeePlace?  @relation("EmployeeLastPlace", fields: [lastPlaceCode], references: [code], onDelete: SetNull)
  documents           Document[]
  user                User?

  @@index([lastName])
  @@index([firstName])
  @@index([middleName])
  @@index([signature])
  @@index([validFrom])
  @@index([validTo])
  @@index([lastRankCode])
  @@index([lastPlaceCode])
  @@index([lastBeginworkCode])
  @@index([lastName, firstName, middleName])
  @@index([validFrom, validTo])
  @@map("employee")
}

/// Документ (наказ, відпустка, відрядження тощо)
model Document {
  id                String        @id @default(uuid())
  number            String
  date              DateTime      @db.Date
  category          String        @default("Інше")
  typeLabel         String        @map("type_label")
  title             String
  status            String        @default("draft")
  basis             String?       @db.VarChar(10)
  employeeCode      Int           @map("employee_code")
  employee          Employee      @relation(fields: [employeeCode], references: [code], onDelete: Restrict)
  placeCode         Int?          @map("place_code")
  place             Place?        @relation(fields: [placeCode], references: [code], onDelete: Restrict)
  employeePlaceCode Int?          @map("employee_place_code")
  employeePlace     EmployeePlace? @relation(fields: [employeePlaceCode], references: [code], onDelete: Restrict)
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  @@index([status])
  @@index([date])
  @@index([employeeCode])
  @@index([placeCode])
  @@index([employeePlaceCode])
  @@map("document")
}

/// Призначення на посаду — звʼязок many-to-many між Employee і Place
model EmployeePlace {
  code                     Int            @id @default(autoincrement())
  employeeCode             Int            @map("employee")
  employee                 Employee       @relation("EmployeeEmployeePlaces", fields: [employeeCode], references: [code], onDelete: Restrict)
  placeCode                Int?           @map("place")
  place                    Place?         @relation(fields: [placeCode], references: [code], onDelete: Restrict)
  sPlace                   String         @default("") @map("splace") @db.VarChar(100)
  orderCode                Int            @map("whatorder")
  order                    Order @relation(fields: [orderCode], references: [code], onDelete: Restrict)
  validFrom                DateTime       @map("fromdate") @db.Date
  validTo                  DateTime       @default(dbgenerated("'2999-12-31'::date")) @map("todate") @db.Date
  koef                     Float          @default(1)
  percentRate              Float          @default(1) @map("percentrate")
  fullName                 String         @map("fullname") @db.VarChar(1000)
  byReasonOfUnitRename     String         @default("F") @map("byreasonof_unitrename") @db.Char(1)
  lastPlaceForEmployee     Employee?      @relation("EmployeeLastPlace")
  deletedAt                DateTime?      @map("deleted_at")
  documents                Document[]

  @@index([employeeCode])
  @@index([placeCode])
  @@index([validFrom])
  @@index([validTo])
  @@map("employee_places")
}
