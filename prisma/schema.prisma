// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  name               String?
  mustChangePassword Boolean   @default(false) @map("must_change_password")
  tempPassword       String?   @map("temp_password")
  passwordChangedAt  DateTime? @map("password_changed_at")
  blocked            Boolean   @default(false)
  blockReason        String?   @map("block_reason")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  sessions           Session[]
  accounts           Account[]
  roles              UserRole[]
  groups             UserGroup[]
  permissions        UserPermission[]
  /// Прив'язка до картки співробітника (legacy WEB_MEN.MAN → MAN.CODE); опційно
  employeeCode       Int?      @unique @map("employee_code")
  employee           Employee? @relation(fields: [employeeCode], references: [code], onDelete: SetNull)
  // --- Better Auth (обов'язкові колонки; у додатку не читаються й не пишуться) ---
  /// За замовчуванням false; верифікація email не увімкнена
  emailVerified      Boolean   @default(false)
  image              String?

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id         String  @id
  accountId  String
  providerId String
  userId     String
  password   String?
  // --- Better Auth: OAuth (обов'язкові колонки; не використовуються — залишаються NULL) ---
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  // --- Better Auth: метадані (у додатку не читаються) ---
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

/// Коди верифікації Better Auth; у додатку не використовується
model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Role {
  id       Int        @id @default(autoincrement())
  roleName String     @unique
  notes    String?
  users    UserRole[]

  @@map("role")
}

model UserRole {
  userId String
  roleId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_role")
}

model Group {
  id          String            @id @default(uuid())
  name        String
  slug        String            @unique
  description String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  permissions GroupPermission[]
  users       UserGroup[]

  @@map("group")
}

model Permission {
  id          String             @id @default(uuid())
  code        String             @unique
  label       String
  description String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  groups      GroupPermission[]
  users       UserPermission[]

  @@map("permission")
}

model GroupPermission {
  groupId      String
  permissionId String
  group        Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([groupId, permissionId])
  @@index([permissionId])
  @@map("group_permission")
}

model UserGroup {
  userId  String
  groupId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
  @@index([groupId])
  @@map("user_group")
}

model UserPermission {
  userId       String
  permissionId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@index([permissionId])
  @@map("user_permission")
}

/// Довідник типів наказів (DORDER)
model DOrder {
  code Int    @id @default(autoincrement())
  val  String

  @@map("dorder")
}

/// Наказ (ORDERS)
model PersonnelOrder {
  code       Int        @id @default(autoincrement())
  orderWhose Int        @map("order_whose")
  orderNo    String     @map("order_no")
  orderDate  DateTime   @map("order_date")
  employeePlaces  EmployeePlace[]

  @@index([orderWhose])
  @@index([orderDate])
  @@map("orders")
}

/// Довідник найменувань підрозділів (DUNIT)
model DUnit {
  code Int    @id @default(autoincrement())
  val  String @unique
  key  String

  @@map("dunit")
}

/// Довідник найменувань посад (DPLACE)
model DPlace {
  code Int    @id @default(autoincrement())
  val  String @unique

  @@map("dplace")
}

/// Підрозділ (UNITS)
model OrgUnit {
  code             Int       @id @default(autoincrement())
  parentCode       Int?      @map("parent")
  parent           OrgUnit?  @relation("OrgUnitTree", fields: [parentCode], references: [code], onDelete: Restrict)
  children         OrgUnit[] @relation("OrgUnitTree")
  unitTypeCode     Int       @map("unit")
  name             String    @default("") @map("name")
  shortName        String?   @map("short_name")
  city             String    @default("")
  sortOrder        Int       @map("unit_id")
  validFrom        DateTime  @map("create_date") @db.Date
  validTo          DateTime? @map("destroy_date") @db.Date
  createOrderCode  Int       @map("create_order")
  destroyOrderCode Int?      @map("destroy_order")
  stationing       String    @default("Нема даних")
  places           Place[]

  @@index([parentCode])
  @@index([parentCode, sortOrder])
  @@index([validFrom, validTo])
  @@map("units")
}

/// Штатна посада (PLACES)
model Place {
  code             Int        @id @default(autoincrement())
  orgUnitCode      Int        @map("unit")
  orgUnit          OrgUnit    @relation(fields: [orgUnitCode], references: [code], onDelete: Restrict)
  placeTypeCode    Int        @map("place")
  sortOrder        Int        @default(0) @map("place_id")
  posCount         Float      @default(1) @map("pos_count")
  isChief          Boolean    @default(false) @map("is_chief")
  manCount         Int        @default(0) @map("man_count")
  validFrom        DateTime   @map("create_date") @db.Date
  validTo          DateTime?  @map("destroy_date") @db.Date
  createOrderCode  Int        @map("create_order")
  destroyOrderCode Int?       @map("destroy_order")
  employeePlaces        EmployeePlace[]
  documents             Document[]

  @@index([orgUnitCode])
  @@index([orgUnitCode, sortOrder])
  @@index([validFrom, validTo])
  @@map("places")
}

/// Співробітник (EMPLOYEE) — відповідає таблиці MAN у Firebird staff
model Employee {
  code                Int        @id @default(autoincrement())
  lastName            String     @map("lastname")
  signature           String
  firstName           String     @map("firstname")
  middleName          String     @map("middlename")
  bornPlace           String     @default("Нема даних") @map("bornplace")
  birthday            DateTime?  @db.Date
  personalNo          String?    @map("personalno") @db.Char(8)
  /// FK → DNATIONALITY.CODE (довідник ще не мігровано)
  nationalityCode     Int        @map("nationality")
  sex                 String     @default("Ч") @db.Char(1)
  idNo                String?    @unique @map("idno") @db.Char(10)
  /// FK → DWHEREFREE.CODE (довідник ще не мігровано)
  fromWhereCode       Int        @map("fromwhere")
  sciLevel            String?    @map("scilevel")
  sciRank             String?    @map("scirank")
  vonDate             DateTime?  @map("vondate") @db.Date
  vlastCalced         DateTime?  @map("vlastcalced") @db.Date
  /// FK → DFAMILYMODE.CODE (довідник ще не мігровано)
  familyModeCode      Int        @map("familymode")
  homeAddress         String     @default("Нема даних") @map("homeaddress")
  validFrom           DateTime?  @map("fromdate") @db.Date
  validTo             DateTime   @default(dbgenerated("'2999-12-31'::date")) @map("todate") @db.Date
  lastRankCode        Int?       @map("last_rank")
  lastPlaceCode       Int?       @unique @map("last_place")
  lastBeginworkCode   Int?       @map("last_beginwork")
  lastEducationCode   Int?       @map("last_education")
  lastMaryCode        Int?       @map("last_mary")
  remarks             String?
  employeePlaces      EmployeePlace[] @relation("EmployeeEmployeePlaces")
  lastPlace           EmployeePlace?  @relation("EmployeeLastPlace", fields: [lastPlaceCode], references: [code], onDelete: SetNull)
  documents           Document[]
  user                User?

  @@index([lastName])
  @@index([firstName])
  @@index([middleName])
  @@index([signature])
  @@index([validFrom])
  @@index([validTo])
  @@index([lastRankCode])
  @@index([lastPlaceCode])
  @@index([lastBeginworkCode])
  @@index([lastName, firstName, middleName])
  @@index([validFrom, validTo])
  @@map("employee")
}

/// Документ (наказ, відпустка, відрядження тощо)
model Document {
  id                String        @id @default(uuid())
  number            String
  date              DateTime      @db.Date
  category          String        @default("Інше")
  typeLabel         String        @map("type_label")
  title             String
  status            String        @default("draft")
  employeeCode      Int           @map("employee_code")
  employee          Employee      @relation(fields: [employeeCode], references: [code], onDelete: Restrict)
  placeCode         Int?          @map("place_code")
  place             Place?        @relation(fields: [placeCode], references: [code], onDelete: Restrict)
  employeePlaceCode Int?          @map("employee_place_code")
  employeePlace     EmployeePlace? @relation(fields: [employeePlaceCode], references: [code], onDelete: Restrict)
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  @@index([status])
  @@index([date])
  @@index([employeeCode])
  @@index([placeCode])
  @@index([employeePlaceCode])
  @@map("document")
}

/// Призначення на посаду — звʼязок many-to-many між Employee і Place
model EmployeePlace {
  code                     Int            @id @default(autoincrement())
  employeeCode             Int            @map("employee")
  employee                 Employee       @relation("EmployeeEmployeePlaces", fields: [employeeCode], references: [code], onDelete: Restrict)
  placeCode                Int?           @map("place")
  place                    Place?         @relation(fields: [placeCode], references: [code], onDelete: Restrict)
  sPlace                   String         @default("") @map("splace")
  orderCode                Int            @map("whatorder")
  order                    PersonnelOrder @relation(fields: [orderCode], references: [code], onDelete: Restrict)
  validFrom                DateTime       @map("fromdate") @db.Date
  validTo                  DateTime       @default(dbgenerated("'2999-12-31'::date")) @map("todate") @db.Date
  koef                     Float          @default(1)
  percentRate              Float          @default(1) @map("percentrate")
  fullName                 String         @map("fullname")
  byReasonOfUnitRename     String         @default("F") @map("byreasonof_unitrename") @db.Char(1)
  lastPlaceForEmployee     Employee?      @relation("EmployeeLastPlace")
  deletedAt                DateTime?      @map("deleted_at")
  documents                Document[]

  @@index([employeeCode])
  @@index([placeCode])
  @@index([validFrom])
  @@index([validTo])
  @@map("employee_places")
}
